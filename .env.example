# Copy to .env and fill in real values — never commit .env
GDELT_CLOUD_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
REDIS_URL=redis://localhost:6379

# Ollama local inference — set OLLAMA_ENABLED=True for local dev
OLLAMA_ENABLED=False
OLLAMA_BASE_URL=http://localhost:11434
# Create at https://ollama.com/settings/keys — required for web search fallback
OLLAMA_API_KEY=

HF_TOKEN=

