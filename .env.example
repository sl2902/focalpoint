# Copy to .env and fill in real values — never commit .env
GDELT_CLOUD_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
REDIS_URL=redis://localhost:6379

# Mobile — Expo reads EXPO_PUBLIC_* vars at build time.
# For a physical device change this to your Mac's local IP (e.g. http://192.168.1.x:8000).
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Ollama local inference — set OLLAMA_ENABLED=True for local dev
OLLAMA_ENABLED=False
OLLAMA_BASE_URL=http://localhost:11434
# Create at https://ollama.com/settings/keys — required for web search fallback
OLLAMA_API_KEY=

HF_TOKEN=

# ACLED credentials — kept for reactivation if API access is granted
# ACLED_USERNAME=
# ACLED_PASSWORD=
# ACLED_TOKEN_URL=https://acleddata.com/oauth/token
